{
    "layers": {
        "place":            { "minzoom":  0, "maxzoom": 16 },
        "boundary":         { "minzoom":  0, "maxzoom": 16, "simplify_below": 12, "simplify_level": 0.0001, "simplify_ratio": 0, "simplify_algorithm": "visvalingam" },

        "poi":              { "minzoom": 0, "maxzoom": 16 },
        "poi_detail":       { "minzoom": 0, "maxzoom": 16, "write_to": "poi"},

        "housenumber":      { "minzoom": 0, "maxzoom": 16 },

        "waterway":         { "minzoom":  0,  "maxzoom": 16, "simplify_below": 12, "simplify_level": 0.0003, "simplify_ratio": 0 },
        "waterway_detail":  { "minzoom": 0,  "maxzoom": 16, "write_to": "waterway" },

        "transportation":             { "minzoom": 4,  "maxzoom": 16, "simplify_below": 13, "simplify_level": 0.0003 },
        "transportation_name":        { "minzoom": 8,  "maxzoom": 16 },

        "building":         { "minzoom": 10, "maxzoom": 16 },

        "water":             { "minzoom": 0,  "maxzoom": 16, "simplify_below": 12, "simplify_level": 0.0003, "simplify_ratio": 0},
        "ocean":             { "minzoom": 0,  "maxzoom": 16, "source": "coastline/water_polygons.shp", "filter_below": 12, "filter_area": 0.5, "simplify_below": 13, "simplify_level": 0.0001, "simplify_ratio": 0, "simplify_algorithm": "visvalingam", "write_to": "water" },
        "water_name":        { "minzoom": 0, "maxzoom": 16 },
        "water_name_detail": { "minzoom": 0, "maxzoom": 16, "write_to": "water_name" },

        "aeroway":           { "minzoom": 0, "maxzoom": 16 },
        "aerodrome_label":   { "minzoom": 0, "maxzoom": 16 },
        "park":              { "minzoom": 0, "maxzoom": 16 },
        "landuse":           { "minzoom":  0, "maxzoom": 16, "simplify_below": 13, "simplify_level": 0.00001, "simplify_ratio": 0 },
        "urban_areas":       { "minzoom":  4, "maxzoom":  16, "source": "landcover/ne_10m_urban_areas/ne_10m_urban_areas.shp", "source_columns": ["featurecla"], "simplify_below": 7, "simplify_level": 0.0003, "simplify_ratio": 0, "write_to": "landuse" },
        "landcover":         { "minzoom":  0, "maxzoom": 16, "simplify_below": 13, "simplify_level": 0.0003, "simplify_ratio": 0 },
        "ice_shelf":         { "minzoom":  0, "maxzoom":  16, "source": "landcover/ne_10m_antarctic_ice_shelves_polys/ne_10m_antarctic_ice_shelves_polys.shp", "source_columns": ["featurecla"], "simplify_below": 13, "simplify_level": 0.0005, "write_to": "landcover" },
        "glacier":           { "minzoom":  2, "maxzoom":  16, "source": "landcover/ne_10m_glaciated_areas/ne_10m_glaciated_areas.shp", "source_columns": ["featurecla"], "simplify_below": 13, "simplify_level": 0.0005, "write_to": "landcover" },
        "mountain_peak":     { "minzoom": 0, "maxzoom": 16 },
        "vietnam_islands_custom": {
            "source": "vietnam-islands",
            "type": "geojson",
            "source_columns": ["name", "name:vi", "name:latin", "place"], 
            "minzoom": 0,
            "maxzoom": 16,
            "write_to": "place"
        }
    },
    "settings": {
        "minzoom": 0,
        "maxzoom": 16,
        "basezoom": 16,
        "include_ids": false,
        "combine_below": 14,
        "name": "Tilemaker to OpenMapTiles schema",
        "version": "3.0",
        "description": "Tile config based on OpenMapTiles schema",
	    "additional_sources": {
        	"vietnam-islands": "vietnam-islands.geojson"
    	},
        "compress": "gzip",
        "filemetadata": {
            "tilejson": "2.0.0",
            "scheme": "xyz",
            "type": "vector",
            "format": "pbf"
        }
    }
}
